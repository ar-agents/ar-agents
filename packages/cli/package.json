{
  "name": "@ar-agents/cli",
  "version": "0.1.0",
  "description": "Command-line client for the ar-agents studio: log in with an anonymous account or an existing token, and check who you are (usage, cap, and society status) offline-verifiable, no browser required.",
  "keywords": [
    "cli",
    "ar-agents",
    "argentina",
    "studio",
    "login",
    "whoami"
  ],
  "license": "MIT",
  "author": "Nazareno Clemente <naza@naza.ar>",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/naza00000"
  },
  "homepage": "https://github.com/ar-agents/ar-agents/tree/main/packages/cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ar-agents/ar-agents.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/ar-agents/ar-agents/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "ar-agents": "./bin/ar-agents.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "validate": "publint && attw --pack .",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
