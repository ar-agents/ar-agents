{
  "name": "@ar-agents/constancia",
  "version": "0.1.0",
  "description": "ARCA (ex-AFIP) Constancia de Inscripción — the official, legally-citable fiscal document, including the PDF artifact — as a typed tool for AI agents on the Vercel AI SDK. Browser-backed: drives the public web form (no Clave Fiscal) behind a stable adapter contract. The piece the SOAP padrón webservices can't give you.",
  "keywords": [
    "constancia-inscripcion",
    "afip",
    "arca",
    "argentina",
    "cuit",
    "monotributo",
    "kyc",
    "regtech",
    "compliance",
    "browser-automation",
    "ai-sdk",
    "vercel-ai",
    "agent",
    "agentic"
  ],
  "license": "MIT",
  "author": "Nazareno Clemente <naza@helloastro.co>",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/naza00000"
  },
  "homepage": "https://github.com/ar-agents/ar-agents/tree/main/packages/constancia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ar-agents/ar-agents.git",
    "directory": "packages/constancia"
  },
  "bugs": {
    "url": "https://github.com/ar-agents/ar-agents/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE",
    "tools.manifest.json"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'",
    "validate": "publint && attw --pack .",
    "size": "size-limit",
    "clean": "rm -rf dist"
  },
  "size-limit": [
    {
      "name": "ESM",
      "path": "dist/index.js",
      "limit": "10 KB"
    },
    {
      "name": "CJS",
      "path": "dist/index.cjs",
      "limit": "10 KB"
    }
  ],
  "peerDependencies": {
    "ai": ">=6.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "ai": "^6.0.175",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
