{
  "name": "@ar-agents/aduana",
  "version": "0.2.2",
  "description": "ARCA Aduana (formerly AFIP Aduana / María) agent toolkit for the Vercel AI SDK 6. Look up import/export declarations by SUSI/KIM/OM number, status of an in-flight despacho, and the publicly-available tariff nomenclature (NCM). Adapter pattern: typed mock out of the box, pluggable HTTP adapter for the ARCA REST API published in 2025.",
  "keywords": [
    "aduana",
    "arca",
    "afip",
    "maria",
    "ncm",
    "comercio-exterior",
    "ar-agents",
    "argentina",
    "ai-sdk",
    "vercel-ai",
    "agent",
    "trade"
  ],
  "license": "MIT",
  "author": "Nazareno Clemente <naza@naza.ar>",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/naza00000"
  },
  "homepage": "https://github.com/ar-agents/ar-agents/tree/main/packages/aduana",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ar-agents/ar-agents.git",
    "directory": "packages/aduana"
  },
  "bugs": {
    "url": "https://github.com/ar-agents/ar-agents/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./tools.manifest.json": "./tools.manifest.json"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE",
    "tools.manifest.json"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "validate": "publint && attw --pack .",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "ai": ">=6.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "ai": "^7.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@ar-agents/core": "workspace:^"
  }
}
