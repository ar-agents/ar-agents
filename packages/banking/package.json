{
  "name": "@ar-agents/banking",
  "version": "0.5.3",
  "description": "Argentine banking primitives (CBU/CVU validation + bank lookup) plus BCRA Central de Deudores AND BCRA Principales Variables (USD, CER, UVA, reservas, BADLAR, inflación) as drop-in tools for the Vercel AI SDK. Pure-algorithm out of the box; BCRA lookups via pluggable adapters.",
  "keywords": [
    "cbu",
    "cvu",
    "bcra",
    "argentina",
    "banking",
    "ai-sdk",
    "vercel-ai",
    "agent",
    "agentic"
  ],
  "license": "MIT",
  "author": "Nazareno Clemente <naza@naza.ar>",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/naza00000"
  },
  "homepage": "https://github.com/ar-agents/ar-agents/tree/main/packages/banking",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ar-agents/ar-agents.git",
    "directory": "packages/banking"
  },
  "bugs": {
    "url": "https://github.com/ar-agents/ar-agents/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "testing": [
        "./dist/testing.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      },
      "require": {
        "types": "./dist/testing.d.cts",
        "default": "./dist/testing.cjs"
      }
    },
    "./tools.manifest.json": "./tools.manifest.json"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE",
    "tools.manifest.json"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'",
    "validate": "publint && attw --pack .",
    "size": "size-limit",
    "clean": "rm -rf dist"
  },
  "size-limit": [
    {
      "name": "ESM",
      "path": "dist/index.js",
      "limit": "10 KB"
    },
    {
      "name": "CJS",
      "path": "dist/index.cjs",
      "limit": "10 KB"
    }
  ],
  "peerDependencies": {
    "ai": ">=6.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "ai": "^7.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "banking": "./bin/banking.js"
  },
  "dependencies": {
    "@ar-agents/core": "workspace:^"
  }
}
