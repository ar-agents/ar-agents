{
  "name": "@ar-agents/firma-digital",
  "version": "0.3.1",
  "description": "Argentine Firma Digital (Ley 25.506 / ONTI) verification primitives as drop-in tools for the Vercel AI SDK. Parse X.509 certs, validate chains anchored at AC-Raíz Argentina, verify CMS/PKCS#7 detached signatures, extract CUIT from signer subject. Read-only: intended for verification, not signing (signing requires hardware tokens).",
  "keywords": [
    "firma-digital",
    "argentina",
    "onti",
    "ac-raiz",
    "ley-25506",
    "x509",
    "pkcs7",
    "cms",
    "ai-sdk",
    "vercel-ai",
    "agent",
    "agentic"
  ],
  "license": "MIT",
  "author": "Nazareno Clemente <naza@naza.ar>",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/naza00000"
  },
  "homepage": "https://github.com/ar-agents/ar-agents/tree/main/packages/firma-digital",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ar-agents/ar-agents.git",
    "directory": "packages/firma-digital"
  },
  "bugs": {
    "url": "https://github.com/ar-agents/ar-agents/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'",
    "validate": "publint && attw --pack .",
    "size": "size-limit",
    "clean": "rm -rf dist"
  },
  "size-limit": [
    {
      "name": "ESM",
      "path": "dist/index.js",
      "limit": "20 KB",
      "ignore": [
        "node-forge"
      ]
    },
    {
      "name": "CJS",
      "path": "dist/index.cjs",
      "limit": "20 KB",
      "ignore": [
        "node-forge"
      ]
    }
  ],
  "peerDependencies": {
    "ai": ">=6.0.0",
    "zod": ">=3.0.0"
  },
  "dependencies": {
    "@ar-agents/core": "workspace:^",
    "node-forge": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/node-forge": "^1.3.14",
    "ai": "^7.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
