{
  "name": "@ar-agents/identity-attest",
  "version": "0.4.2",
  "description": "Identity attestation pattern for AI agents \u2014 orchestrate verification flows (WhatsApp OTP, email magic link, Auth0, MercadoPago Identity, SID gov) and get back a signed attestation with a trust level. The RENAPER workaround that lets agents do KYC without institutional API access.",
  "keywords": [
    "identity",
    "kyc",
    "attestation",
    "verification",
    "otp",
    "magic-link",
    "ai-sdk",
    "vercel-ai",
    "agent",
    "agentic",
    "renaper",
    "argentina"
  ],
  "license": "MIT",
  "author": "Nazareno Clemente <naza@helloastro.co>",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/naza00000"
  },
  "homepage": "https://github.com/ar-agents/ar-agents/tree/main/packages/identity-attest",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ar-agents/ar-agents.git",
    "directory": "packages/identity-attest"
  },
  "bugs": {
    "url": "https://github.com/ar-agents/ar-agents/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./auth0": {
      "import": {
        "types": "./dist/auth0.d.ts",
        "default": "./dist/auth0.js"
      },
      "require": {
        "types": "./dist/auth0.d.cts",
        "default": "./dist/auth0.cjs"
      }
    },
    "./magic-link-sdk": {
      "import": {
        "types": "./dist/magic-link-sdk.d.ts",
        "default": "./dist/magic-link-sdk.js"
      },
      "require": {
        "types": "./dist/magic-link-sdk.d.cts",
        "default": "./dist/magic-link-sdk.cjs"
      }
    },
    "./tools.manifest.json": "./tools.manifest.json"
  },
  "typesVersions": {
    "*": {
      "auth0": [
        "./dist/auth0.d.ts"
      ],
      "magic-link-sdk": [
        "./dist/magic-link-sdk.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE",
    "tools.manifest.json"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'",
    "validate": "publint && attw --pack .",
    "size": "size-limit",
    "clean": "rm -rf dist"
  },
  "size-limit": [
    {
      "name": "ESM",
      "path": "dist/index.js",
      "limit": "30 KB",
      "ignore": [
        "node:crypto",
        "crypto"
      ]
    },
    {
      "name": "CJS",
      "path": "dist/index.cjs",
      "limit": "30 KB",
      "ignore": [
        "node:crypto",
        "crypto"
      ]
    }
  ],
  "peerDependencies": {
    "ai": ">=6.0.0",
    "zod": ">=3.0.0",
    "@magic-sdk/admin": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@ar-agents/whatsapp": {
      "optional": true
    },
    "@magic-sdk/admin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ar-agents/whatsapp": "workspace:*",
    "@magic-sdk/admin": "^2.8.2",
    "@types/node": "^20.19.39",
    "ai": "^6.0.175",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@ar-agents/core": "workspace:^",
    "jose": "^6.2.3"
  }
}
