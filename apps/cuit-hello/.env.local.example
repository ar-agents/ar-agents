# Vercel AI Gateway (or BYOK with ANTHROPIC_API_KEY)
AI_GATEWAY_API_KEY=

# Override the default model
# CUIT_AGENT_MODEL=anthropic/claude-sonnet-4-6

# AFIP cert + key for v0.2 padron lookup. When all three are set, the agent
# wires the real WsaaWscdcAfipPadronAdapter from @ar-agents/identity/wsaa.
# Until set, the agent only validates CUIT format + check digit; the
# lookup_cuit_afip tool returns a "not configured" message.
#
# Setup walkthrough:
#   1. openssl genrsa -out afip-key.pem 2048
#   2. openssl req -new -key afip-key.pem \
#        -subj "/C=AR/O=YourOrg/CN=ar-agents/serialNumber=CUIT YYYYYYYYYY" \
#        -out afip.csr
#   3. Login to AFIP, "Administración de Certificados Digitales", upload .csr
#   4. Download the .pem AFIP issues
#   5. "Administrador de Relaciones de Clave Fiscal" → authorize ws_sr_padron_a5
#   6. Set the env vars below.
#
# AFIP_CERT_PATH=/absolute/path/to/afip-cert.pem
# AFIP_KEY_PATH=/absolute/path/to/afip-key.pem
# AFIP_CUIT_REPRESENTADO=20XXXXXXXXY
# AFIP_ENV=homo
