# Vercel AI Gateway (or BYOK with ANTHROPIC_API_KEY)
AI_GATEWAY_API_KEY=

# Override the default model
# CUIT_AGENT_MODEL=anthropic/claude-sonnet-4-6

# AFIP cert + key for v0.2 padron lookup. Until set, the agent only validates
# CUIT format + check digit; lookup_cuit_afip returns a "not configured" message.
# See src/lib/afip-stub.ts for the full setup walkthrough.
# AFIP_CERT_PATH=/absolute/path/to/afip.crt
# AFIP_KEY_PATH=/absolute/path/to/afip-key.pem
# AFIP_CUIT_REPRESENTADO=20XXXXXXXXY
# AFIP_ENV=homo
