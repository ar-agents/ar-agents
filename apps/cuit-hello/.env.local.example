# Vercel AI Gateway (or BYOK with ANTHROPIC_API_KEY)
AI_GATEWAY_API_KEY=

# Override the default model
# CUIT_AGENT_MODEL=anthropic/claude-sonnet-4-6

# AFIP cert + key for v0.2 padron lookup. The agent wires the real
# WsaaWscdcAfipPadronAdapter from @ar-agents/identity/wsaa. Without these
# vars, lookup_cuit_afip returns a "not configured" message.
#
# Setup walkthrough:
#   1. openssl genrsa -out afip-key.pem 2048
#   2. openssl req -new -key afip-key.pem \
#        -subj "/C=AR/O=YourOrg/CN=ar-agents/serialNumber=CUIT YYYYYYYYYY" \
#        -out afip.csr
#   3. Login to AFIP, "Administración de Certificados Digitales", upload .csr
#   4. Download the .pem AFIP issues
#   5. "Administrador de Relaciones de Clave Fiscal" → "Nueva Relación" →
#      WebServices → "Servicio Consulta Padron A13" → as Representante,
#      select the alias (Computador Fiscal). Note: AFIP deprecated A5; A13
#      is the current canonical service.
#   6. Set the env vars below.
#
# Local dev (filesystem):
#   AFIP_CERT_PATH=/absolute/path/to/afip-cert.pem
#   AFIP_KEY_PATH=/absolute/path/to/afip-key.pem
#
# Vercel / serverless (paste PEM contents directly — multiline OK in Vercel
# dashboard; if your shell mangles newlines, base64-encode and decode at
# runtime):
#   AFIP_CERT_PEM=-----BEGIN CERTIFICATE-----\nMIIE...\n-----END CERTIFICATE-----
#   AFIP_KEY_PEM=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----
#
# Always required:
#   AFIP_CUIT_REPRESENTADO=20XXXXXXXXY
#   AFIP_ENV=prod  # or "homo"
