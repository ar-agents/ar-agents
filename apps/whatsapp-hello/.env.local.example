# Vercel AI Gateway (or BYOK with ANTHROPIC_API_KEY)
AI_GATEWAY_API_KEY=

# Override the default model
# WSP_AGENT_MODEL=anthropic/claude-sonnet-4-6

# AFIP / ARCA padron lookup. Wire to enable real CUIT lookups via @ar-agents/identity.
# Default service is ws_sr_constancia_inscripcion (returns monotributo + IVA condition).
# AFIP_CERT_PEM=-----BEGIN CERTIFICATE-----\n...
# AFIP_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...
# AFIP_CUIT_REPRESENTADO=20XXXXXXXXY
# AFIP_ENV=prod

# Mercado Pago Subscriptions. Without this, MP tools are not registered.
# MP_ACCESS_TOKEN=APP_USR-...

# WhatsApp Business Cloud API. Without these, the WhatsApp tools run in
# MOCK MODE — all send_* calls are recorded and shown in the demo UI but no
# real WhatsApp message is sent. Get accessToken + phoneNumberId from
# Meta Business Suite → WhatsApp → API Setup.
# WA_ACCESS_TOKEN=EAA...
# WA_PHONE_NUMBER_ID=...
# WA_WEBHOOK_VERIFY_TOKEN=any-string-you-pick (must match Meta dashboard)
# META_APP_SECRET=... (Meta dashboard → App Settings → Basic)
