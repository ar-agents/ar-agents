# Required for the live "Try with your own prompt" demo on the landing.
# The /api/demo route uses @ai-sdk/anthropic with this key. Get one at
# https://console.anthropic.com/. Used model: claude-haiku-4-5.
#
# In production this must be set as an Encrypted env var on the
# `ar-agents` Vercel project. Without it the live demo button will still
# render, but every request returns 500 — the scripted tabs above keep
# working since they're 100% client-side.
ANTHROPIC_API_KEY=
