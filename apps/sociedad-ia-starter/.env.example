# Sociedad-IA starter — variables de entorno.
# Copialo a .env.local y completá los valores. Cada variable está
# documentada en /lib/clients.ts (los valores faltantes degradan
# graciosamente — el agente queda sin esos tools pero la app sigue arriba).

# ---- Agent endpoint auth (REQUERIDO) --------------------------------------
# POST /api/agent corre el loop del agente (tools reales + tokens pagos), así
# que exige API key y NO arranca hasta setear esto (responde 503). Generá una:
#   openssl rand -hex 32
# Los clientes mandan:  Authorization: Bearer <AGENT_API_KEY>
AGENT_API_KEY=

# ---- Studio status endpoint auth (opcional, la provisiona studio sola) ----
# GET /api/status es el diagnóstico que lee el cockpit de studio ("la
# sociedad en vivo"): deploy, clientes conectados, kill switch, aprobaciones
# pendientes, acciones recientes. Si desplegaste desde studio con un token de
# Vercel configurado, esta variable ya está seteada. NO arranca (responde
# 503) hasta setearla. Los clientes mandan: Authorization: Bearer <token>.
STUDIO_STATUS_TOKEN=

# ---- LLM provider ---------------------------------------------------------
# El starter usa Anthropic Claude por default. Para usar OpenAI cambiá
# `lib/agent.ts` para importar de @ai-sdk/openai.
ANTHROPIC_API_KEY=

# ---- AFIP / ARCA ----------------------------------------------------------
# Cert X.509 + private key emitidos por ARCA → Clave Fiscal → Asociar
# Servicio Web. Asociá el alias a los servicios "wsfe" (factura
# electrónica) y "ws_sr_constancia_inscripcion" (padron).
AFIP_CERT_PEM=
AFIP_KEY_PEM=
AFIP_CUIT=
AFIP_ENV=homo                 # "homo" para sandbox, "prod" para vivo
AFIP_PTO_VTA=1                # punto de venta habilitado en ARCA

# ---- Mercado Pago ---------------------------------------------------------
# developers.mercadopago.com → Tu app → Credenciales de Producción.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ---- WhatsApp Business ----------------------------------------------------
# Meta Business Manager → WhatsApp Business → API.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=          # para verificar firmas HMAC del webhook
WHATSAPP_VERIFY_TOKEN=        # token para handshake del webhook

# ---- BCRA -----------------------------------------------------------------
# Opcional. La librería usa el endpoint público por default. Setealo si
# tenés un proxy o un mirror propio.
BCRA_DEUDORES_URL=

# ---- Sociedad-IA metadata -------------------------------------------------
# Nombre real de la sociedad. Lo lee la homepage pública (/) y GET
# /api/status. Si desplegaste desde studio ya está seteado (studio lo
# provisiona con el nombre real de la sociedad, ROADMAP.md M3-3). Sin esto
# la homepage muestra "Sociedad automatizada", nunca un placeholder de
# ejemplo.
SOCIEDAD_IA_DENOMINACION=ACME-AI SAS
SOCIEDAD_IA_CUIT=

# URL de ar-agents studio, el cockpit desde el que se opera esta sociedad.
# La homepage pública (/) enlaza acá. Opcional: sin setear usa el studio
# público (studio-plum-three-47.vercel.app).
STUDIO_URL=

# ---- Audit + HITL ---------------------------------------------------------
# 32+ caracteres aleatorios, independiente de cualquier otro secreto. Firma
# (HMAC-SHA256) cada entrada del audit log LOCAL de esta sociedad (lib/audit-log.ts):
# cada tool call del agent loop -- éxito, error, o un refuse de gobernanza --
# queda ahí, no sólo los actos administrativos. Si desplegaste desde studio
# esta variable ya está seteada (studio la provisiona igual que
# STUDIO_STATUS_TOKEN). Opcional: sin ella las entradas se siguen guardando,
# sólo quedan sin firmar (hmac: null). Ver GET /api/status -> audit.
AUDIT_HMAC_SECRET=

# URL que la librería va a hitear para gates de confirmación humana
# en operaciones irreversibles (refunds, cancellations, transferencias).
REQUIRE_CONFIRMATION_WEBHOOK=

# ---- Cron protection ------------------------------------------------------
# Vercel Cron envía Authorization: Bearer <CRON_SECRET>. Setealo para
# que /api/cron/morning rechace requests sin el header.
CRON_SECRET=
