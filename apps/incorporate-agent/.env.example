# Copy to .env.local. eve needs Node 24+.

# The model runs through the Vercel AI Gateway. Bring one key (or any
# provider key the Gateway accepts). Get one at vercel.com/ai-gateway.
AI_GATEWAY_API_KEY=

# Optional. From POST https://ar-agents.ar/api/auditor/activate.
# Without it, registrar_decision returns a structured "not configured"
# result instead of writing a durable signed audit entry.
AUDITOR_API_KEY=
