# Mercado Pago Sandbox credentials
# Generate at: https://www.mercadopago.com.ar/developers/panel/credentials
# Use the TEST access token (NOT production) for safe testing
MP_ACCESS_TOKEN=TEST-...

# Optional: where MP sends the customer after first payment completes
# In production, this should be your real domain
MP_BACK_URL=http://localhost:3000/subscription/done

# Vercel AI Gateway
# Get a key at: https://vercel.com/dashboard/ai-gateway/api-keys
# (or use BYOK by setting your provider key directly, e.g. ANTHROPIC_API_KEY)
AI_GATEWAY_API_KEY=...

# Override the model used by the agent (default: anthropic/claude-sonnet-4-6)
# Examples: anthropic/claude-opus-4-7, openai/gpt-5, google/gemini-2.5-pro
# MP_AGENT_MODEL=anthropic/claude-sonnet-4-6

# Upstash Redis (for subscription state persistence)
# Create a free Redis database at https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
