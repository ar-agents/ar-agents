# apps/studio env vars. Everything here is optional; the app degrades
# gracefully with no env vars set (in-memory storage, no model configured ->
# POST /api/agent answers 503 until at least one model key is set).
# See docs/CONTRACT.md.

# OpenRouter key for the "coach" model tier (default nvidia/nemotron-3-nano-30b-a3b:free).
OPENROUTER_API_KEY=

# Vercel AI Gateway key for the "build" and hard-fallback model tiers
# (default deepseek/deepseek-v4-flash, then anthropic/claude-haiku-4.5).
AI_GATEWAY_API_KEY=

# Overrides the default "coach" tier model id (a plain OpenRouter model id).
STUDIO_COACH_MODEL=

# Overrides the default "build" tier model id (a plain "provider/model" gateway id).
STUDIO_BUILD_MODEL=

# Monthly free cap per account, in micro-USD of ESTIMATED model cost (1 USD = 1,000,000).
# Default 500000 (0.50 USD of cost). Nothing is actually charged in v1; this only
# gates further /api/agent calls.
STUDIO_FREE_CAP_MICRO_USD=

# The deployment's pricing factor (a plain positive number), applied to metered model
# cost to compute the estimated price shown in the dashboard once billing goes live.
# Default 5. Server-only; never sent to the client or stated on any public surface.
STUDIO_PRICE_MULTIPLIER=

# Base URL for the public ar-agents.ar API this app orchestrates. Default https://ar-agents.ar.
STUDIO_ARAGENTS_BASE=

# Vercel KV (Upstash) REST credentials. Unset -> in-memory storage (fine for local dev;
# state does not survive a restart and does not share across serverless isolates).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Tavily API key for the agent's research_web tool (live web search to validate
# a market before recommending a build). Free tier available at tavily.com.
# Unset -> the tool is not registered and the coach says live search is unavailable.
TAVILY_API_KEY=

# Enables POST /api/society/deploy's "provisioned" mode: studio creates a real
# Vercel project + deployment for a constituted society's agent app. Unset ->
# "manual" mode (a one-click deploy link + .env to paste in yourself).
# Create a scoped token at vercel.com/account/settings/tokens (Project: Full
# Access is enough; do not use a token with broader account scope than needed).
VERCEL_PROVISION_TOKEN=

# Scopes every Vercel API call above to this team (adds ?teamId=). Unset ->
# calls run against the token owner's personal account.
VERCEL_TEAM_ID=
